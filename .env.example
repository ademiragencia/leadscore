# LeadScore Empresas
PORT=4173
HOST=127.0.0.1
NODE_ENV=development

# Limites de assinatura aplicados no backend: basic, pro, agency, enterprise.
PLAN_LEVEL=agency

# CNPJ
# brasilapi funciona sem chave para consulta individual por CNPJ.
CNPJ_PROVIDER=brasilapi
# Para provedor pago/parceiro:
# CNPJ_PROVIDER=partner
# PARTNER_CNPJ_API_URL=https://seu-provedor.example/cnpj/{cnpj}
# PARTNER_CNPJ_API_KEY=

# Busca ampla de empresas por cidade, CNAE, porte, capital etc.
# Para vender acesso completo, use base nacional local importada ou base parceira com uso permitido.
# Se omitido, o sistema usa ./data/national-leads.
# NATIONAL_LEADS_DIR=C:\bases\leadscore\national-leads
# FORCE_PARTNER_LEADS_API=false
#
# API parceira opcional:
# A API deve aceitar POST { "filters": { ... } } e retornar { "companies": [...] }.
# PARTNER_LEADS_API_URL=https://seu-provedor.example/leads/search
# PARTNER_LEADS_API_KEY=

# Enriquecimento de contatos permitidos.
# A API deve aceitar POST { "company": { ... } } e retornar { "contacts": [...], "company": { ... } }.
# CONTACT_ENRICHMENT_API_URL=https://seu-provedor.example/contacts/enrich
# CONTACT_ENRICHMENT_API_KEY=

# IA para mensagens de abordagem.
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# CRM externo via webhook.
# A API deve aceitar POST { "leads": [...] }.
# CRM_WEBHOOK_URL=https://seu-crm.example/webhook/leadscore
# CRM_WEBHOOK_KEY=

# WhatsApp Cloud API. Por segurança, o envio automático só acontece se o front pedir send=true.
# Sem essas chaves, o backend retorna um link wa.me.
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=v20.0
